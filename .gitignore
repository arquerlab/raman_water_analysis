# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# OS / editor files
.DS_Store
Thumbs.db
.vscode/
.idea/

# Build / packaging
build/
dist/
*.egg-info/

# Results and figures (can be regenerated)
results/*.png
results/*.svg

# Large raw data (if you keep it separate)
data/raw/

# Logs / temporary files
*.log
*.tmp

